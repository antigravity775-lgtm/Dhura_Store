generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  fullName     String
  phoneNumber  String?
  email        String    @unique
  passwordHash String
  role         Role      @default(Buyer)
  city         String?
  isVerified   Boolean   @default(false)
  isBlocked    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  orders       Order[]   @relation("BuyerOrders")
  products     Product[] @relation("SellerProducts")

  @@index([phoneNumber])
  @@index([city])
}

model Category {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  iconUrl   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[] @relation("CategoryProducts")

  @@index([name])
}

model Product {
  id             String      @id @default(uuid()) @db.Uuid
  title          String
  description    String
  price          Decimal     @db.Decimal(18, 2)
  currency       Currency    @default(YER_Sanaa)
  condition      Condition   @default(New)
  stockQuantity  Int
  mainImageUrl   String?
  isHidden       Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  categoryId     String      @db.Uuid
  sellerId       String      @db.Uuid
  discountPrice  Decimal?    @db.Decimal(18, 2)
  isPromoted     Boolean     @default(false)
  promotionLabel String?
  OrderItem      OrderItem[]
  category       Category    @relation("CategoryProducts", fields: [categoryId], references: [id])
  seller         User        @relation("SellerProducts", fields: [sellerId], references: [id])

  @@index([isHidden, isPromoted, createdAt(sort: Desc)])
  @@index([sellerId, createdAt(sort: Desc)])
  @@index([categoryId, isHidden, isPromoted])
  @@index([discountPrice])
}

model Order {
  id              String        @id @default(uuid()) @db.Uuid
  totalAmount     Decimal       @db.Decimal(18, 2)
  currency        Currency      @default(YER_Sanaa)
  status          OrderStatus   @default(Pending)
  shippingAddress String
  paymentMethod   PaymentMethod @default(COD)
  orderDate       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  buyerId         String        @db.Uuid
  buyer           User          @relation("BuyerOrders", fields: [buyerId], references: [id])
  orderItems      OrderItem[]   @relation("OrderItems")

  @@index([buyerId, orderDate(sort: Desc)])
  @@index([status, orderDate(sort: Desc)])
}

model OrderItem {
  id        String   @id @default(uuid()) @db.Uuid
  quantity  Int
  unitPrice Decimal  @db.Decimal(18, 2)
  createdAt DateTime @default(now())
  orderId   String   @db.Uuid
  productId String   @db.Uuid
  order     Order    @relation("OrderItems", fields: [orderId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model SystemSetting {
  id           String   @id @default("global")
  aboutUsText  String   @default("سوق إلكتروني يمني يوفر أفضل المنتجات...")
  contactEmail String   @default("info@al-gaadi.com")
  contactPhone String   @default("+967 77X XXX XXX")
  shippingOfferText String @default("شحن مجاني للطلبات فوق 50$")
  facebookUrl  String?
  twitterUrl   String?
  whatsappUrl  String?
  instagramUrl String?
  updatedAt    DateTime @updatedAt
}

enum Role {
  Admin
  Seller
  Buyer
}

enum Condition {
  New
  Used
  Refurbished
}

enum Currency {
  YER_Sanaa
  YER_Aden
  USD
  SAR
  EUR
}

enum OrderStatus {
  Pending
  Processing
  Shipped
  Delivered
  Cancelled
  Confirmed
}

enum PaymentMethod {
  COD
  BankTransfer
  CreditCard
  CashOnDelivery
}

model RateLimit {
  key       String   @id
  hits      Int      @default(0)
  resetTime DateTime
}
