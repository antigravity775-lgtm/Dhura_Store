generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  fullName     String
  phoneNumber  String?
  email        String    @unique
  passwordHash String
  role         Role      @default(Buyer)
  city         String?
  isVerified   Boolean   @default(false)
  isBlocked    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  orders       Order[]   @relation("BuyerOrders")
  products     Product[] @relation("SellerProducts")
  cartItems    CartItem[]
  favorites     Favorite[]
  auditLogs     AuditLog[]
  refreshTokens RefreshToken[]

  @@index([phoneNumber])
  @@index([city])
}

model Category {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  iconUrl   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[] @relation("CategoryProducts")

  @@index([name])
}

model Product {
  id             String      @id @default(uuid()) @db.Uuid
  title          String
  slug           String      @unique
  description    String
  price          Decimal     @db.Decimal(18, 2)
  currency       Currency    @default(YER_Sanaa)
  condition      Condition   @default(New)
  stockQuantity  Int
  mainImageUrl   String?
  isHidden       Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  categoryId     String      @db.Uuid
  sellerId       String      @db.Uuid
  discountPrice  Decimal?    @db.Decimal(18, 2)
  isPromoted     Boolean     @default(false)
  promotionLabel String?
  OrderItem      OrderItem[]
  cartItems      CartItem[]
  favorites      Favorite[]
  category       Category    @relation("CategoryProducts", fields: [categoryId], references: [id])
  seller         User        @relation("SellerProducts", fields: [sellerId], references: [id])

  @@index([isHidden, isPromoted, createdAt(sort: Desc)])
  @@index([sellerId, createdAt(sort: Desc)])
  @@index([categoryId, isHidden, isPromoted])
  @@index([discountPrice])
}

model Order {
  id              String        @id @default(uuid()) @db.Uuid
  totalAmount     Decimal       @db.Decimal(18, 2)
  currency        Currency      @default(YER_Sanaa)
  status          OrderStatus   @default(Pending)
  shippingAddress String
  paymentMethod   PaymentMethod @default(COD)
  orderDate       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  buyerId         String        @db.Uuid
  buyer           User          @relation("BuyerOrders", fields: [buyerId], references: [id])
  orderItems      OrderItem[]   @relation("OrderItems")

  @@index([buyerId, orderDate(sort: Desc)])
  @@index([status, orderDate(sort: Desc)])
}

model OrderItem {
  id        String   @id @default(uuid()) @db.Uuid
  quantity  Int
  unitPrice Decimal  @db.Decimal(18, 2)
  createdAt DateTime @default(now())
  orderId   String   @db.Uuid
  productId String   @db.Uuid
  order     Order    @relation("OrderItems", fields: [orderId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model SystemSetting {
  id           String   @id @default("global")
  aboutUsText  String   @default("سوق إلكتروني يمني يوفر أفضل المنتجات...")
  contactEmail String   @default("info@al-gaadi.com")
  contactPhone String   @default("+967 77X XXX XXX")
  shippingOfferText String @default("شحن مجاني للطلبات فوق 50$")
  facebookUrl  String?
  twitterUrl   String?
  whatsappUrl  String?
  instagramUrl String?
  tiktokUrl    String?
  seoTitle     String?
  seoDescription String?
  updatedAt    DateTime @updatedAt
}

enum Role {
  Admin
  Seller
  Buyer
}

enum BannerPlacement {
  promo_home
  announcement
  category
  product
  sidebar
  footer
  popup
  hero
}

enum BannerStatus {
  active
  draft
  scheduled
  archived
}

model Banner {
  id             String          @id @default(uuid()) @db.Uuid
  title          String
  subtitle       String?
  description    String?
  ctaText        String?
  ctaUrl         String?
  imageUrl       String?
  mobileImageUrl String?
  bgColor        String?
  textAlign      String          @default("right")
  overlayOpacity Int             @default(30)
  placement      BannerPlacement @default(promo_home)
  status         BannerStatus    @default(draft)
  showOnDesktop  Boolean         @default(true)
  showOnMobile   Boolean         @default(true)
  priority       Int             @default(0)
  scheduledAt    DateTime?
  expiresAt      DateTime?
  impressions    Int             @default(0)
  clicks         Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([placement, status, priority])
  @@index([status, scheduledAt])
}

enum Condition {
  New
  Used
  Refurbished
}

enum Currency {
  YER_Sanaa
  YER_Aden
  USD
  SAR
  EUR
}

enum OrderStatus {
  Pending
  Processing
  Shipped
  Delivered
  Cancelled
  Confirmed
}

enum PaymentMethod {
  COD
  BankTransfer
  CreditCard
  CashOnDelivery
}

model RateLimit {
  key       String   @id
  hits      Int      @default(0)
  resetTime DateTime
}

model CartItem {
  id        String   @id @default(uuid()) @db.Uuid
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String   @db.Uuid
  productId String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

model Favorite {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now())
  userId    String   @db.Uuid
  productId String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  tokenHash  String    @unique
  userId     String    @db.Uuid
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?
  replacedBy String?   @db.Uuid
  userAgent  String?
  ipAddress  String?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  action    String
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
  userId    String?  @db.Uuid
  user      User?    @relation(fields: [userId], references: [id])

  @@index([action])
  @@index([createdAt(sort: Desc)])
}
