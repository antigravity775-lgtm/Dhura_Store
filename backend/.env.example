# Node.js Backend Environment Variables
# Copy this file to .env and fill in the values

# Server Configuration
PORT=5000

# Database Connection (Supabase PostgreSQL)
# Get your Supabase connection string from your Supabase project settings
# Format: postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-ID].supabase.co:5432/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:your-password@db.your-project-id.supabase.co:5432/postgres?sslmode=require

# Optional: use same value as DATABASE_URL unless you have a special non-pooled connection string
DIRECT_URL=postgresql://postgres:your-password@db.your-project-id.supabase.co:5432/postgres?sslmode=require

# JWT Configuration
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRES_IN=1h

# Currency Converter Configuration (Exchange Rates)
# These rates are used to convert between currencies
USD_TO_YER_SANAA_RATE=530
USD_TO_YER_ADEN_RATE=1650

# File Upload Configuration
# Maximum file size for uploads (in bytes)
MAX_FILE_SIZE=5242880 # 5MB

# Allowed file types for uploads
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif