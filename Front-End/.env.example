# Frontend Environment Variables
# Copy this file to .env.local for local development
# In production (Vercel), set these in the Vercel project dashboard under Settings > Environment Variables

# The full URL to your deployed backend API, including /api suffix
# Example: https://your-backend-name.vercel.app/api
# Leave blank (or don't set) for local development — the Vite proxy will forward /api to localhost:5000
VITE_API_URL=
